{
  "name": "mass-balance-csp",
  "version": "1.3.1",
  "description": "Mass Balance – Caustic Soda Plant",
  "author": "Akshay Aghera",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AkshayAghera/Mass-Balance---Caustic-Soda-Plant.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "npx shx mkdir -p dist && npx shx cp index.html logo.png dist/",
    "deploy": "electron-builder --win --x64 --publish always",
    "mobile:sync": "npx cap sync android"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/assets": "^3.0.5",
    "shx": "^0.3.4"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0"
  },
  "capacitor": {
    "appId": "com.akshayaghera.massbalance",
    "appName": "Mass Balance CSP",
    "webDir": "dist",
    "plugins": {
      "SplashScreen": {
        "launchShowDuration": 3000,
        "launchAutoHide": true,
        "backgroundColor": "#ffffff",
        "androidScaleType": "CENTER_CROP",
        "showSpinner": true,
        "splashFullScreen": true,
        "splashImmersive": true
      }
    }
  }
}