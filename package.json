{
  "name": "mass-balance-csp",
  "version": "1.2.9",
  "description": "Mass Balance – Caustic Soda Plant",
  "author": "Akshay Aghera",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AkshayAghera/Mass-Balance---Caustic-Soda-Plant.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "mkdir -p dist && cp index.html logo.png dist/ || (mkdir dist & copy index.html dist\\ & copy logo.png dist\\)",
    "deploy": "electron-builder --win --x64 --publish always",
    "mobile:sync": "npx cap sync android"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/assets": "^3.0.5"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0"
  },
  "capacitor": {
    "appId": "com.akshayaghera.massbalance",
    "appName": "Mass Balance CSP",
    "webDir": "dist",
    "plugins": {
      "SplashScreen": {
        "launchShowDuration": 3000,
        "launchAutoHide": true,
        "backgroundColor": "#ffffff",
        "androidScaleType": "CENTER_CROP",
        "showSpinner": true,
        "splashFullScreen": true,
        "splashImmersive": true
      }
    }
  },
  "build": {
    "appId": "com.csp.massbalance",
    "productName": "Mass Balance CSP 2026",
    "publish": [
      {
        "provider": "github",
        "owner": "AkshayAghera",
        "repo": "Mass-Balance---Caustic-Soda-Plant"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    }
  }
}